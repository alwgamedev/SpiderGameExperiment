    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "HeightMultiplier",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float y = position.y;\nif (y <= hMin)\n{\n\tm = 0;\n}\nelse if (y > hMax)\n{\n\tm = 1;\n}\nelse\n{\n\tm = pow((y - hMin) / (hMax - hMin), hPower);\n}"
}

