    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "BorderValue",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float scale = max(objectScale.x, objectScale.y);\nfloat worldDistToBorder = localDistToBorder * scale;\nborderVal = (borderWorldWidth - worldDistToBorder) / borderWorldWidth;\nborderVal = clamp(borderVal, 0, 1);"
}

