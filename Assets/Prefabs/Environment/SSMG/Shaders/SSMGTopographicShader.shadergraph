    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "Combine3Colors",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float sumInv = 1 / (t1 + t2 + t3 + t4);\nt1 *= sumInv;\nt2 *= sumInv;\nt3 *= sumInv;\nt4 *= sumInv;\ncolor = t1 * color1 + t2 * color2 + t3 * color3 + t4 * color4\n;"
}

