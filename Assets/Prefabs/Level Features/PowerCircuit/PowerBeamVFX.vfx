  m_OperatorName: Custom HLSL
  m_HLSLCode: "float MiddleThicknessMultiplier(float t, float middleThickness)\n{\n 
    float s = t - 0.5;\n  s = 4 * s * s;\n  return lerp(middleThickness, 1, s);\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: MiddleThicknessMultiplier
    selectedIndex: 0
