  m_Name: 
  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Operator.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 114350483966674976}
  m_Children: []
  m_UIPosition: {x: 1108, y: 3301}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 8926484042661615543}
  m_OutputSlots:
  - {fileID: 8926484042661615544}
  m_OperatorName: Custom HLSL
  m_HLSLCode: "float CheapSine(in float value)\n{\n\tfloat k = floor(value);\n\tfloat
    t = value - k;\n\tfloat s = 4 * t * (t - 1);\n\tfloat sign = -2 * abs(k % 2)
    + 1;\n\treturn sign * s;\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunctions:
    selection: CheapSine
    selectedIndex: 0
