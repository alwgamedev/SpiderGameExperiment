  m_OperatorName: Custom HLSL
  m_HLSLCode: "float FloatFunction(float t, float middleThickness)\n{\n  float s
    = t - 0.5;\n  s = 4 * s * s;\n  return lerp(middleThickness, 1, s);\n}"
